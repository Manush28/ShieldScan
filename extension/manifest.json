{
  "manifest_version": 3,
  "name": "ShieldScan",
  "version": "1.0",
  "description": "Real-time phishing detection",
  "permissions": ["tabs", "activeTab", "storage"],
  "host_permissions": ["http://127.0.0.1:8000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
